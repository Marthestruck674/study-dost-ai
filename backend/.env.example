# Copy this file to .env and fill in your real key
FEATHERLESS_API_KEY=your_featherless_api_key_here

# Optional: a backup key. If the primary returns 401/402/429, the server
# will automatically fall over to this one. Leave blank to disable.
FEATHERLESS_API_KEY_BACKUP=
# (You can also add FEATHERLESS_API_KEY_BACKUP_2 or
#  FEATHERLESS_API_KEYS=key1,key2,key3 for more.)

# Comma-separated list of allowed origins for CORS.
# Use * for any origin (fine for early testing). For prod, lock to your domain:
#   ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# Optional: protect your API with a shared secret. If set, the frontend must
# send header  X-API-Key: <this value>
# Leave empty to disable.
APP_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
